{
  "name": "desktop-sticky-note",
  "version": "1.0.0",
  "description": "桌面便签应用",
  "author": "hcb422",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "installer": "electron-builder"
  },
  "build": {
    "appId": "com.desktop.stickynote",
    "productName": "DesktopStickyNote",
    "electronDist": "node_modules/electron/dist",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "signAndEditExecutable": false,
      "artifactName": "桌面便签_Setup_${version}.${ext}"
    },
    "nsis": {
      "shortcutName": "桌面便签",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  }
}
